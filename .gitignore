# Heavy data files are NOT tracked in git (multi-GB CSVs).
# We keep folder structure (.gitkeep) and small docs/audits (READMEs, *_cleaning_audit.csv).
# `**` means everything recursively; whitelist with !path/.

# ----- data/raw -----
data/raw/**
!data/raw/.gitkeep
!data/raw/reviews/
!data/raw/reviews/README.md
!data/raw/reviews/_eda/
!data/raw/reviews/_eda/**
!data/raw/calendars/
!data/raw/calendars/README.md
!data/raw/listing/
!data/raw/listing/README.md

# ----- data/processed -----
data/processed/**
!data/processed/.gitkeep
!data/processed/review/
!data/processed/review/.gitkeep
!data/processed/review/README.md
!data/processed/review/_eda/
!data/processed/review/_eda/**
!data/processed/calendar/
!data/processed/calendar/README.md
!data/processed/calendar/calendar_cleaning_audit.csv
!data/processed/listing/
!data/processed/listing/README.md

# ----- results (large per-run outputs) -----
!results/04_guest_experience/text_features/
!results/04_guest_experience/text_features/README.md
# Text-mining artefacts too large for GitHub (regenerate via scripts/text_analysis/)
results/04_guest_experience/text_features/*.npz
results/04_guest_experience/text_features/listing_city_deviation_terms.csv
results/01_market_analysis/reviews/**
!results/01_market_analysis/reviews/.gitkeep
results/01_market_analysis/calendars/**
!results/01_market_analysis/calendars/.gitkeep
reports/reviews/**
reports/calendars/**

# ----- local / OS artifacts -----
.cache/
__pycache__/
*.pyc
.venv/
venv/
.DS_Store
**/.DS_Store

# ----- internal-only docs -----
HOW_TO_USE_DRIVE_FOLDER.md
**/HOW_TO_USE_DRIVE_FOLDER.md
**/*_CN.md
