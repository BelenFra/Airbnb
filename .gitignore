# Ignore heavy/raw data files
data/raw/
data/raw/**
!data/raw/.gitkeep
!data/raw/reviews/
!data/raw/reviews/README.md
!data/raw/calendars/
!data/raw/calendars/README.md
data/processed/**
!data/processed/reviews/
!data/processed/reviews/.gitkeep
!data/processed/reviews/README.md
!data/processed/calendars/
!data/processed/calendars/.gitkeep
!data/processed/calendars/README.md
!data/processed/calendars/calendars_cleaning_audit.csv
results/reviews/**
!results/reviews/.gitkeep
results/calendars/**
!results/calendars/.gitkeep
reports/reviews/**
reports/calendars/**

# Optional local artifacts
.cache/
__pycache__/
*.pyc
*.csv
*.gz

# Tracked despite *.csv: small audit metadata
!data/processed/calendars/calendars_cleaning_audit.csv

# macOS Finder metadata
.DS_Store
**/.DS_Store

# Internal-only docs (do not commit)
HOW_TO_USE_DRIVE_FOLDER.md
**/HOW_TO_USE_DRIVE_FOLDER.md

# Chinese-language doc copies (do not commit)
**/*_CN.md
