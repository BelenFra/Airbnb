# Heavy data files are NOT tracked in git (multi-GB CSVs).
# GitHub rejects blobs roughly >100 MB (and warns well below that). `.gitignore`
# cannot filter by file size — block risky CSV classes by path pattern below instead.
# We keep folder structure (.gitkeep) and small docs/audits (READMEs, *_cleaning_audit.csv,
# market/segment summaries under results/). Large masters, merged tables, per-city *_cleaned.csv,
# and investment_decision/*.csv are ignored explicitly below.
# `**` means everything recursively; whitelist with !path/.

# ----- data/raw -----
data/raw/**
!data/raw/.gitkeep
!data/raw/reviews/
!data/raw/reviews/README.md
!data/raw/reviews/_eda/
!data/raw/reviews/_eda/**
!data/raw/calendars/
!data/raw/calendars/README.md
!data/raw/listing/
!data/raw/listing/README.md

# ----- data/processed -----
data/processed/**
!data/processed/.gitkeep
!data/processed/review/
!data/processed/review/.gitkeep
!data/processed/review/README.md
!data/processed/review/_eda/
!data/processed/review/_eda/**
!data/processed/calendar/
!data/processed/calendar/README.md
!data/processed/calendar/calendar_cleaning_audit.csv
!data/processed/listing/
!data/processed/listing/README.md

# ----- results (large per-run outputs) -----
!results/04_guest_experience/text_features/
!results/04_guest_experience/text_features/README.md
# Text-mining artefacts too large for GitHub (regenerate via scripts/models/text_analysis/)
results/04_guest_experience/text_features/*.npz
results/04_guest_experience/text_features/listing_city_deviation_terms.csv
# Listing-level indices / metadata (~1 row per listing; regenerated with listing_tfidf_matrix.npz)
results/04_guest_experience/text_features/listing_documents_meta.csv
results/04_guest_experience/text_features/listing_tfidf_row_index.csv

# ----- large / regenerable CSVs (multi-MB–GB; never commit) -----
# Merged masters and per-city cleaned exports (cleaning pipeline / local copies anywhere in the tree).
**/listing_all_cleaned.csv
**/reviews_all_cleaned.csv
**/all_reviews_cleaned.csv
**/master_data.csv
**/calendar_all_cleaned.csv
**/occupation_all_cleaned.csv
**/calendar_*_cleaned.csv
**/occupation_*_cleaned.csv
**/listing_*_cleaned.csv
**/reviews_*_cleaned.csv

# Investment-decision quantitative outputs (wide tables; regenerate via scripts/models/investment_decision/).
results/investment_decision/**/*.csv
data/processed/investment_decision/**/*.csv

results/01_market_analysis/reviews/**
!results/01_market_analysis/reviews/.gitkeep
!results/01_market_analysis/reviews/reviews_cleaning_audit.csv
results/01_market_analysis/calendars/**
!results/01_market_analysis/calendars/.gitkeep
!results/01_market_analysis/calendars/calendars_cleaning_audit.csv
reports/reviews/**
reports/calendars/**

# Legacy stray audit folders — audits belong under results/01_market_analysis/{reviews,calendars}/
results/reviews/**
results/calendars/**

# ----- local / OS artifacts -----
.cache/
__pycache__/
*.pyc
.venv/
venv/
.DS_Store
**/.DS_Store

# Notebook superseded by scripts/04_guest_experience/run_guest_experience_charts.py
results/04_guest_experience/guest_experience_charts.ipynb

# ----- internal-only docs -----
HOW_TO_USE_DRIVE_FOLDER.md
**/HOW_TO_USE_DRIVE_FOLDER.md
**/*_CN.md
